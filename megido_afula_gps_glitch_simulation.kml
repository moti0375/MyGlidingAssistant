      <styleUrl>#glitchStyle</styleUrl>
      <Point><coordinates>34.79250,32.09900,54</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>GLITCH-13</name>
      <styleUrl>#glitchStyle</styleUrl>
      <Point><coordinates>34.79150,32.09750,55</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>GLITCH-14</name>
      <styleUrl>#glitchStyle</styleUrl>
      <Point><coordinates>34.79050,32.09650,53</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>GLITCH-15</name>
      <styleUrl>#glitchStyle</styleUrl>
      <Point><coordinates>34.78950,32.09550,51</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>GLITCH-16</name>
      <styleUrl>#glitchStyle</styleUrl>
      <Point><coordinates>34.78850,32.09450,50</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>GLITCH-17</name>
      <styleUrl>#glitchStyle</styleUrl>
      <Point><coordinates>34.78750,32.09350,52</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>GLITCH-18</name>
      <styleUrl>#glitchStyle</styleUrl>
      <Point><coordinates>34.78650,32.09250,54</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>GLITCH-19</name>
      <styleUrl>#glitchStyle</styleUrl>
      <Point><coordinates>34.78550,32.09150,53</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>GLITCH-20 · last glitch fix</name>
      <styleUrl>#glitchStyle</styleUrl>
      <Point><coordinates>34.78450,32.09050,51</coordinates></Point>
    </Placemark>

    <!-- ═══════════════════════════════════════════════════
         POST-GLITCH ROUTE  (9 waypoints — mid → Afula)
         Resumes exactly where the route was interrupted.
    ═══════════════════════════════════════════════════ -->
    <Placemark>
      <name>09 · Route Resumes</name>
      <styleUrl>#normalStyle</styleUrl>
      <Point><coordinates>35.25430,32.60210,198</coordinates></Point>
    </Placemark>

