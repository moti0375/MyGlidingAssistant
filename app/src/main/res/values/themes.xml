<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.App" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Semantic Colors -->
        <item name="colorPrimary">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>

        <!-- 1. Fix Status Bar Icons (Turn clock/battery black) -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- 2. Fix Toolbar Icon/Text Tinting globally -->
        <item name="colorControlNormal">@color/black</item>

        <!-- 3. Fix the Overflow menu (3 dots) specifically -->
        <item name="actionOverflowButtonStyle">@style/Widget.ActionButton.Overflow</item>

        <item name="windowActionModeOverlay">true</item>
        <item name="actionModeBackground">@color/white</item>
        <item name="actionModeStyle">@style/Widget.App.ActionMode</item>
    </style>

    <!-- Style to force 3-dots to black if the above doesn't catch it -->
    <style name="Widget.ActionButton.Overflow" parent="Widget.AppCompat.ActionButton.Overflow">
        <item name="android:tint">@color/black</item>
    </style>

    <style name="Widget.App.ActionMode" parent="Widget.AppCompat.ActionMode">
        <item name="titleTextStyle">@style/TextAppearance.App.ActionModeTitle</item>
    </style>

    <style name="TextAppearance.App.ActionModeTitle" parent="TextAppearance.AppCompat.Widget.ActionMode.Title">
        <item name="android:textColor">@color/black</item>
    </style>
</resources>